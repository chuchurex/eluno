{
  "name": "eluno",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "El Uno — The Law of One in a philosophical lens",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chuchurex/eluno.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@eluno/core": "github:chuchurex/eluno-core#v2",
    "dotenv": "^17.0.0",
    "node-edge-tts": "^1.2.10",
    "node-id3": "^0.2.9",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "live-server": "^1.2.2",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.8.1",
    "puppeteer": "^24.0.0",
    "wrangler": "^4.28.0"
  },
  "scripts": {
    "build": "eluno-build",
    "sass:build": "sass node_modules/@eluno/core/scss/main.scss:dist/css/main.css --style=compressed",
    "sass:watch": "sass --watch node_modules/@eluno/core/scss/main.scss:dist/css/main.css",
    "dev": "concurrently \"npm run sass:watch\" \"live-server dist --port=4025\"",
    "build:pdf": "node scripts/build-pdf.cjs",
    "audio:extract": "eluno-audio extract",
    "audio:generate": "eluno-audio generate",
    "audio:assemble": "eluno-audio assemble",
    "audio:concat": "eluno-audio concat",
    "audio:tag": "eluno-audio tag",
    "audio:all": "eluno-audio all",
    "integrate": "node scripts/integrate-chapter.js",
    "translate": "node scripts/translate-chapter.js",
    "build:distill": "npm run build --prefix distill",
    "dev:distill": "npm run dev --prefix distill",
    "deploy:distill": "node scripts/deploy-distill.cjs",
    "pages:create-distill": "node scripts/pages-create-distill.cjs",
    "pages:domain-distill": "node scripts/pages-add-custom-domain.cjs distill.eluno.org distill",
    "dns:distill-pages": "node scripts/dns-add-pages-cname.cjs distill distill-krl.pages.dev",
    "upload:distill-audio": "node scripts/upload-distill-audio.cjs",
    "lint": "npx eslint scripts/",
    "lint:fix": "npx eslint scripts/ --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "validate": "npm run lint && npm run format:check && npm run test:json",
    "test": "node --test tests/",
    "test:json": "node scripts/validate-json.js",
    "test:alignment": "node scripts/validate-alignment.js all",
    "prepare": "husky"
  },
  "lint-staged": {
    "scripts/**/*.js": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "npx prettier --write"
    ],
    "i18n/**/*.json": [
      "node scripts/validate-json.js"
    ]
  }
}
