# =============================================================================
# eluno — Environment Variables
# =============================================================================
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# SITE - Used by build (@eluno/core)
# All optional — defaults to eluno.org values if omitted
# -----------------------------------------------------------------------------
SITE_URL=https://your-domain.com
GA_ID=G-XXXXXXXXXX
# GITHUB_REPO=https://github.com/your-user/your-repo  # omit to hide link

# -----------------------------------------------------------------------------
# ANTHROPIC - Automated translation (scripts/translate-chapter.js)
# Required for: /write:publish (phase 7 — translates EN → ES/PT)
# Get your key: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# -----------------------------------------------------------------------------
# STATIC SERVER - SSH/RSYNC for audio hosting (MP3 audiobooks)
# Used by: audiobook upload scripts (scp/rsync to static server)
# Only needed if you host audio on a separate server
# -----------------------------------------------------------------------------
UPLOAD_HOST=your-server-ip
UPLOAD_PORT=22
UPLOAD_USER=your-username
UPLOAD_PASS=your-password
UPLOAD_DIR=/path/to/public_html

# -----------------------------------------------------------------------------
# CLOUDFLARE - Cache purge, DNS, Pages management
# Used by: manual cache purge after deploy, wrangler CLI
# Dashboard: https://dash.cloudflare.com/
# -----------------------------------------------------------------------------
CF_API_KEY=your-api-key
CF_EMAIL=your-email
CF_ZONE_ID=your-zone-id
CF_ACCOUNT_ID=your-account-id

# Opcional: token API (recomendado por Cloudflare frente a Global API Key + email)
# CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# FISH AUDIO - TTS for audiobook generation (Fish Audio API)
# Used by: scripts/audiobook/generate-fish.cjs
# Only needed if using Fish Audio TTS (alternative to Edge TTS)
# -----------------------------------------------------------------------------
# FISH_API_KEY=your-fish-audio-api-key
# FISH_VOICE_ID=your-default-voice-id
# FISH_VOICE_ID_ES=your-spanish-voice-id
# FISH_VOICE_ID_EN=your-english-voice-id

# Deploy manual de distill (npm run deploy:distill) — nombre del proyecto en Pages
# CF_PAGES_PROJECT_DISTILL=distill
#
# Añadir dominio al proyecto Pages (una vez): npm run pages:domain-distill
# (o: node scripts/pages-add-custom-domain.cjs tu-subdominio.eluno.org nombre-proyecto)
#
# CNAME en la zona hacia *.pages.dev (si Pages no lo creó solo): npm run dns:distill-pages
# Ajusta el target en package.json si Cloudflare asigna otro *.pages.dev al proyecto.
